#!/usr/bin/env bash
#MISE description="Purge all installed skills (with confirmation)"
#MISE depends=["_require-clean"]
set -euo pipefail

echo "This will remove:"
echo "  - All skills in skills/"
echo "  - All skills in shelf/"
echo "  - Agent skill directories (~/.config/opencode/skills/, ~/.codex/skills/)"
echo "  - .skill-lock.json"
echo ""
read -rp "Are you sure? [y/N] " confirm

if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
  echo "Aborted."
  exit 0
fi

# Remove active skills (keep .gitkeep)
find skills/ -mindepth 1 ! -name '.gitkeep' -exec rm -rf {} + 2>/dev/null || true

# Remove shelved skills (keep .gitkeep)
find shelf/ -mindepth 1 ! -name '.gitkeep' -exec rm -rf {} + 2>/dev/null || true

# Clear agent global skill directories
rm -rf ~/.config/opencode/skills/
rm -rf ~/.codex/skills/

# Remove lock file
rm -f .skill-lock.json

echo "All skills purged."
echo "Run 'mise run install <owner/repo>' to reinstall."
